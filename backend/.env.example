# Ozon Seller API
OZON_BASE_URL=https://api-seller.ozon.ru
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key
OZON_MAX_IMAGES_PER_PRODUCT=30

# Yandex Object Storage (S3)
YC_ACCESS_KEY_ID=your_yandex_access_key
YC_SECRET_ACCESS_KEY=your_yandex_secret_key
YC_BUCKET=your_bucket_name
YC_REGION=ru-central1
YC_ENDPOINT_URL=https://storage.yandexcloud.net

# Optional: if set, used to generate public image URLs
# Supports {bucket} placeholder, e.g. https://storage.yandexcloud.net/{bucket}
YC_PUBLIC_BASE_URL=https://storage.yandexcloud.net/{bucket}

# Optional path prefix in bucket
YC_PREFIX=figma-exports

# Optional object ACL (set empty if bucket policy handles public access)
YC_OBJECT_ACL=public-read

# Cleanup scheduler for Yandex bucket
# Important: do NOT set retention too low, Ozon may still fetch images asynchronously
YC_CLEANUP_ENABLED=true
YC_CLEANUP_INTERVAL_HOURS=24
YC_CLEANUP_RETENTION_HOURS=24
YC_CLEANUP_BATCH_SIZE=1000
YC_CLEANUP_MAX_DELETE_PER_RUN=5000
YC_CLEANUP_STARTUP_DELAY_SEC=60

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# Runtime options for container startup (entrypoint.sh)
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info
